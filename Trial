<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tax With Manoj | Simplifying Tax & Business Compliance in Nepal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,600;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* --- ORIGINAL BRAND IDENTITY PALETTE (DITTO) --- */
        :root {
            --primary-navy: #0D1B2A;       /* Deep navy base */
            --secondary-navy: #1B263B;     /* Card background navy */
            --accent-gold: #C8973F;        /* Warm gold accents */
            --light-bg: #0D1B2A;           /* Kept same dark base layout */
            --white: #FFFFFF;
            --text-light: #F8F9FA;         /* Off-white text */
            --text-muted: #A0AAB2;         /* Muted grey-blue text */
            --border-color: rgba(200, 151, 63, 0.2); /* Gold subtle borders */
            --font-sans: 'Montserrat', sans-serif;
            --font-serif: 'Playfair Display', serif;
        }

        /* --- BASE RESETS --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html {
            scroll-behavior: smooth;
        }
        body {
            font-family: var(--font-sans);
            color: var(--text-light);
            background-color: var(--primary-navy);
            line-height: 1.7;
            overflow-x: hidden;
        }
        a {
            text-decoration: none;
            color: inherit;
            transition: all 0.3s ease;
        }

        /* --- UTILITY COMPONENTS --- */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }
        .section-padding {
            padding: 100px 0;
        }
        .label {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: var(--accent-gold);
            font-weight: 600;
            display: inline-block;
            margin-bottom: 12px;
        }
        .section-title {
            font-family: var(--font-serif);
            font-size: 2.5rem;
            color: var(--white);
            line-height: 1.3;
            margin-bottom: 24px;
            font-weight: 600;
        }
        .btn {
            display: inline-block;
            padding: 14px 32px;
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-radius: 0;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .btn-primary {
            background-color: var(--accent-gold);
            color: var(--primary-navy);
            border: 1px solid var(--accent-gold);
        }
        .btn-primary:hover {
            background-color: transparent;
            color: var(--accent-gold);
        }
        .btn-secondary {
            background-color: transparent;
            color: var(--white);
            border: 1px solid var(--white);
        }
        .btn-secondary:hover {
            background-color: var(--white);
            color: var(--primary-navy);
        }

        /* --- TOP UTILITY BAR --- */
        .top-bar {
            background-color: rgba(13, 27, 42, 0.8);
            color: var(--text-light);
            font-size: 13px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .top-bar .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }
        .top-bar-info span {
            margin-right: 24px;
            font-weight: 400;
        }
        .top-bar-info i {
            color: var(--accent-gold);
            margin-right: 8px;
        }

        /* --- MAIN NAVIGATION --- */
        .main-header {
            background-color: var(--primary-navy);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 80px;
        }
        .logo {
            font-family: var(--font-serif);
            font-size: 22px;
            font-weight: 700;
            color: var(--white);
            letter-spacing: 0.5px;
        }
        .logo span {
            color: var(--accent-gold);
        }
        .nav-menu {
            display: flex;
            align-items: center;
        }
        .nav-item {
            margin-left: 35px;
        }
        .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-light);
            position: relative;
            padding: 8px 0;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background-color: var(--accent-gold);
            transition: width 0.3s ease;
        }
        .nav-link:hover::after {
            width: 100%;
        }
        .nav-btn {
            margin-left: 40px;
        }
        .nav-btn .btn {
            padding: 10px 24px;
            font-size: 13px;
        }
        .mobile-toggle {
            display: none;
            font-size: 24px;
            color: var(--white);
            cursor: pointer;
        }

        /* --- HERO SECTION --- */
        .hero {
            background-color: var(--primary-navy);
            padding: 120px 0;
            position: relative;
            overflow: hidden;
        }
        .hero-content {
            max-width: 750px;
            position: relative;
            z-index: 2;
        }
        .hero-tag {
            background: rgba(200, 151, 63, 0.15);
            color: var(--accent-gold);
            padding: 6px 16px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            display: inline-block;
            margin-bottom: 24px;
            border-left: 3px solid var(--accent-gold);
        }
        .hero-headline {
            font-family: var(--font-serif);
            font-size: 3.8rem;
            color: var(--white);
            line-height: 1.2;
            font-weight: 600;
            margin-bottom: 24px;
        }
        .hero-sub {
            font-size: 18px;
            color: var(--text-muted);
            margin-bottom: 40px;
            max-width: 650px;
        }
        .hero-actions .btn {
            margin-right: 16px;
            margin-bottom: 12px;
        }

        /* --- STATS DISPLAY GRID --- */
        .stats-section {
            background-color: var(--secondary-navy);
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            padding: 50px 0;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            text-align: center;
        }
        .stat-item {
            padding: 20px;
            border-right: 1px solid var(--border-color);
        }
        .stat-item:last-child {
            border-right: none;
        }
        .stat-number {
            font-family: var(--font-serif);
            font-size: 3.5rem;
            color: var(--accent-gold);
            font-weight: 700;
            line-height: 1;
            margin-bottom: 8px;
        }
        .stat-label {
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-light);
            font-weight: 500;
        }

        /* --- ABOUT SECTION --- */
        .about-section {
            background-color: var(--primary-navy);
        }
        .about-content {
            max-width: 850px;
            margin: 0 auto;
        }
        .about-text p {
            color: var(--text-muted);
            font-size: 16px;
            margin-bottom: 24px;
        }
        .about-text p:last-of-type {
            margin-bottom: 0;
        }
